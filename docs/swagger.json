{
    "swagger": "2.0",
    "info": {
        "contact": {}
    },
    "paths": {
        "/api/contact": {
            "post": {
                "description": "Принимает данные формы, анализирует тональность через AI, шлет email и возвращает автоответ",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "contact"
                ],
                "summary": "Отправка формы обратной связи",
                "parameters": [
                    {
                        "description": "Данные контакта",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/domain.ContactRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Успешный ответ с AI-автоответом",
                        "schema": {
                            "$ref": "#/definitions/domain.ContactResponse"
                        }
                    },
                    "400": {
                        "description": "Ошибка валидации или неверный JSON",
                        "schema": {
                            "$ref": "#/definitions/domain.ErrorResponse"
                        }
                    },
                    "429": {
                        "description": "Too many requests (спам-защита)",
                        "schema": {
                            "$ref": "#/definitions/domain.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "schema": {
                            "$ref": "#/definitions/domain.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/health": {
            "get": {
                "description": "Возвращает текущий статус сервера (health check)",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Проверка статуса сервиса",
                "responses": {
                    "200": {
                        "description": "Статус OK",
                        "schema": {
                            "$ref": "#/definitions/domain.HealthResponse"
                        }
                    }
                }
            }
        },
        "/api/metrics": {
            "get": {
                "description": "Возвращает общие метрики и тональность обращений из файла",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Статистика обращений",
                "responses": {
                    "200": {
                        "description": "Объект статистики",
                        "schema": {
                            "$ref": "#/definitions/domain.Metrics"
                        }
                    },
                    "500": {
                        "description": "Не удалось прочитать метрики",
                        "schema": {
                            "$ref": "#/definitions/domain.ErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "domain.ContactRequest": {
            "type": "object",
            "required": [
                "comment",
                "email",
                "name",
                "phone"
            ],
            "properties": {
                "comment": {
                    "type": "string",
                    "minLength": 5
                },
                "email": {
                    "type": "string"
                },
                "name": {
                    "type": "string",
                    "minLength": 2
                },
                "phone": {
                    "type": "string"
                }
            }
        },
        "domain.ContactResponse": {
            "type": "object",
            "properties": {
                "ai_reply": {
                    "type": "string",
                    "example": "Здравствуйте! Спасибо за ваше обращение..."
                },
                "sentiment": {
                    "type": "string",
                    "example": "positive"
                },
                "success": {
                    "type": "boolean",
                    "example": true
                }
            }
        },
        "domain.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "Описание ошибки бэкенда"
                }
            }
        },
        "domain.HealthResponse": {
            "type": "object",
            "properties": {
                "status": {
                    "type": "string",
                    "example": "OK"
                }
            }
        },
        "domain.Metrics": {
            "type": "object",
            "properties": {
                "last_update": {
                    "type": "string",
                    "example": "2026-07-17T13:40:00Z"
                },
                "sentiment_stats": {
                    "$ref": "#/definitions/domain.SentimentStats"
                },
                "total_requests": {
                    "type": "integer",
                    "example": 12
                }
            }
        },
        "domain.SentimentStats": {
            "type": "object",
            "properties": {
                "negative": {
                    "type": "integer",
                    "example": 1
                },
                "neutral": {
                    "type": "integer",
                    "example": 3
                },
                "positive": {
                    "type": "integer",
                    "example": 8
                }
            }
        }
    }
}